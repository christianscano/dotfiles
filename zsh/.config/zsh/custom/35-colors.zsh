# # Catppuccin Mocha CLI colors

export EZA_CONFIG_DIR="$HOME/.config/eza"

ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=103'

typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[command]='fg=111'
ZSH_HIGHLIGHT_STYLES[builtin]='fg=111'
ZSH_HIGHLIGHT_STYLES[function]='fg=111'
ZSH_HIGHLIGHT_STYLES[alias]='fg=111'
ZSH_HIGHLIGHT_STYLES[reserved-word]='fg=183'
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=223'
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=223'
ZSH_HIGHLIGHT_STYLES[path]='fg=116,underline'
ZSH_HIGHLIGHT_STYLES[path_pathseparator]='fg=103'
ZSH_HIGHLIGHT_STYLES[globbing]='fg=183'
ZSH_HIGHLIGHT_STYLES[history-expansion]='fg=183'
ZSH_HIGHLIGHT_STYLES[comment]='fg=103'
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=210,bold'
