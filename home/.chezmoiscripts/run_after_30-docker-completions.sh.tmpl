#!/bin/sh
set -u

if ! command -v docker >/dev/null 2>&1; then
	echo "[chezmoi] Docker not found; skipping Docker completions" >&2
	exit 0
fi

completion_dir="$HOME/.config/zsh/completions"
completion_file="${completion_dir}/_docker"
tmp_file="${TMPDIR:-/tmp}/chezmoi-docker-completion.$$"

cleanup() {
	rm -f "$tmp_file"
}
trap cleanup EXIT HUP INT TERM

mkdir -p "$completion_dir"

if ! docker completion zsh >"$tmp_file"; then
	echo "[chezmoi] Failed to generate Docker completions" >&2
	exit 0
fi

if [ -f "$completion_file" ] && cmp -s "$tmp_file" "$completion_file"; then
	exit 0
fi

mv "$tmp_file" "$completion_file"

zcompdump="${ZSH_COMPDUMP:-${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump}"
rm -f "$zcompdump" "${zcompdump}.zwc"
rm -rf "$zcompdump.zwc.lock" 2>/dev/null || true

echo "[chezmoi] Updated Docker completions: $completion_file"
